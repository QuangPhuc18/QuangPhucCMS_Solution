@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống - CMS Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        /* 🔥 ĐÃ CẬP NHẬT: Tone màu Xanh dương mới */
        :root {
            --brand-color: rgb(10, 104, 255); /* Xanh dương chủ đạo */
            --brand-color-hover: rgb(8, 86, 214); /* Xanh đậm hơn khi hover chuột */
            --brand-color-light: #E6F0FF; /* Xanh rất nhạt cho nút SSO */
        }

        body {
            background-color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-x: hidden;
        }

        .bg-brand {
            background-color: var(--brand-color);
        }

        .text-brand {
            color: var(--brand-color);
        }

        .btn-brand {
            background-color: var(--brand-color);
            color: white;
            border: none;
            transition: all 0.3s;
        }

            .btn-brand:hover {
                background-color: var(--brand-color-hover);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(10, 104, 255, 0.4);
            }

        .btn-sso {
            background-color: var(--brand-color-light);
            color: var(--brand-color);
            border: none;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-sso:hover {
                background-color: #cce0ff; /* Đậm hơn một chút xíu khi hover */
                color: var(--brand-color);
            }

        .login-card {
            border-radius: 1.5rem;
            max-width: 420px;
            width: 100%;
        }

        /* Viền input khi click vào cũng chuyển sang màu xanh */
        .form-control:focus {
            border-color: var(--brand-color);
            box-shadow: 0 0 0 0.25rem rgba(10, 104, 255, 0.15);
        }

        /* Logo CSS */
        .logo-circle {
            width: 180px;
            height: 180px;
            background-color: var(--brand-color);
            border-radius: 50%;
            position: relative;
            display: inline-block;
        }

        .logo-inner-circle {
            width: 90px;
            height: 90px;
            background-color: white;
            border-radius: 50%;
            position: absolute;
            top: 45px;
            left: 45px;
        }

        .logo-cutout {
            width: 40px;
            height: 40px;
            background-color: white;
            position: absolute;
            bottom: 25px;
            right: 20px;
            transform: rotate(45deg);
        }
    </style>
</head>
<body>
    <div class="container-fluid vh-100 p-0">
        <div class="row g-0 h-100">

            <div class="col-md-6 d-none d-md-flex flex-column align-items-center justify-content-center bg-white">
                <div class="text-center">
                    <div class="logo-circle shadow-sm">
                        <div class="logo-inner-circle"></div>
                        <div class="logo-cutout"></div>
                    </div>
                    <h1 class="fw-bold mt-4" style="font-size: 3.5rem; color: #1a1e2d; letter-spacing: -1px;">QuanLy_CMS</h1>
                </div>
            </div>

            <div class="col-md-6 d-flex align-items-center justify-content-center bg-brand p-4">

                <div class="card login-card shadow-lg border-0">
                    <div class="card-body p-5">

                        <div class="text-center mb-4">
                            <p class="text-dark fw-bold mb-1" style="font-size: 0.9rem;">Welcome to QuanLy</p>
                            <h2 class="fw-bold" style="font-size: 2.2rem; color: #1a1e2d;">Log in</h2>
                        </div>

                        <form asp-action="Login" method="post">

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger py-2 small text-center fw-bold rounded-3">
                                    <i class="bi bi-exclamation-octagon"></i> @ViewBag.Error
                                </div>
                            }

                            <div class="mb-3">
                                <label class="form-label fw-bold" style="font-size: 0.9rem;">Tên đăng nhập</label>
                                <input type="text" name="username" class="form-control form-control-lg rounded-3 fs-6" placeholder="Nhập tài khoản admin..." required autofocus />
                            </div>

                            <div class="mb-2">
                                <label class="form-label fw-bold" style="font-size: 0.9rem;">Mật khẩu</label>
                                <div class="input-group">
                                    <input type="password" name="password" id="passwordInput" class="form-control form-control-lg rounded-start-3 fs-6 border-end-0" placeholder="••••••••" required />
                                    <span class="input-group-text bg-white rounded-end-3 border-start-0" style="cursor: pointer;" onclick="togglePassword()">
                                        <i class="bi bi-eye text-muted" id="toggleIcon"></i>
                                    </span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4 mt-2" style="font-size: 0.8rem;">
                                <span class="text-muted">No Account ? <a href="#" class="text-brand text-decoration-none fw-bold">Sign up</a></span>
                                <a href="#" class="text-brand text-decoration-none fw-bold">Forgot Password?</a>
                            </div>

                            <button type="submit" class="btn btn-brand btn-lg w-100 rounded-3 fw-bold fs-6 py-2 mb-3">
                                Log in
                            </button>

                            <div class="d-flex align-items-center my-3">
                                <hr class="flex-grow-1 text-muted opacity-25">
                                <span class="mx-3 text-muted" style="font-size: 0.8rem;">OR</span>
                                <hr class="flex-grow-1 text-muted opacity-25">
                            </div>

                            @* <button type="button" class="btn btn-sso btn-lg w-100 rounded-3 fs-6 py-2">
                                <i class="bi bi-shield-check me-1"></i> Use single sign-on (SSO)
                            </button> *@

                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            var passInput = document.getElementById("passwordInput");
            var icon = document.getElementById("toggleIcon");
            if (passInput.type === "password") {
                passInput.type = "text";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                passInput.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }
    </script>
</body>
</html>