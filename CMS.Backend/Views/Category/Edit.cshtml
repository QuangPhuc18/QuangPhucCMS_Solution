@model CMS_DATA.Entities.Category

@{
    ViewData["Title"] = "Chỉnh Sửa Danh Mục";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h4 class="mb-0 text-uppercase fw-bold">
                        <i class="bi bi-pencil-square"></i> Chỉnh Sửa Danh Mục
                    </h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">

                        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control form-control-lg" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <hr class="text-muted" />

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <a asp-action="Index" class="btn btn-light border px-4">
                                Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold text-dark">
                                Cập nhật thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}