@model CMS_DATA.Entities.CategoryProduct

@{
    ViewData["Title"] = "Thêm Danh Mục Mới";
    Layout = "_LayoutAdmin";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0 text-uppercase fw-bold"><i class="bi bi-tag"></i> Thêm Danh Mục Mới</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Tên Danh Mục <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Ví dụ: Cà phê pha máy, Trà trái cây..." autofocus />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả ngắn cho danh mục này..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <hr class="text-muted" />
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light border px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-success px-5 fw-bold">LƯU DANH MỤC</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}