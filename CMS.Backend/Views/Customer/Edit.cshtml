@model CMS_DATA.Entities.Customer

@{
    ViewData["Title"] = "Cập Nhật Khách Hàng";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0 text-uppercase fw-bold"><i class="bi bi-pencil-square"></i> Cập Nhật Thông Tin</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FullName" class="form-label fw-bold">Họ và Tên <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label fw-bold">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold">Địa chỉ Email</label>
                                <input asp-for="Email" type="email" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Password" class="form-label fw-bold">Mật khẩu</label>
                                <input asp-for="Password" type="text" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Address" class="form-label fw-bold">Địa chỉ giao hàng</label>
                            <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                        </div>

                        <hr class="text-muted" />

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light border px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-warning px-5 fw-bold text-dark">CẬP NHẬT THAY ĐỔI</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}