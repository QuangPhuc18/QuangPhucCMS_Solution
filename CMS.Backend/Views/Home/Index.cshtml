@model IEnumerable<CMS_DATA.Entities.Post>

@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2">
        <h2 class="text-danger fw-bold text-uppercase mb-0 border-start border-danger border-4 ps-2">
            Tin Tức Mới Nhất
        </h2>
        <a asp-controller="Post" asp-action="Index" class="text-decoration-none text-danger fw-bold">Xem tất cả &rarr;</a>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card shadow-sm h-100 border-0 post-card-hover">

                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/400x250?text=News" : item.ImageUrl)"
                             class="card-img-top"
                             alt="@item.Title"
                             style="height: 180px; object-fit: cover;">

                        <div class="card-body d-flex flex-column p-3">
                            <div class="mb-2">
                                <span class="badge bg-danger">
                                    @(item.Category != null ? item.Category.Name : "Chưa phân loại")
                                </span>
                            </div>

                            <h6 class="card-title fw-bold" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;">
                                @item.Title
                            </h6>

                            <div class="card-text text-muted small mb-3" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                @Html.Raw(item.Content)
                            </div>

                            <div class="mt-auto">
                                <a asp-controller="Post" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm w-100 fw-bold">
                                    Đọc tiếp
                                </a>
                            </div>
                        </div>

                        <div class="card-footer bg-white text-muted small border-top-0 pt-0 pb-3">
                            <i class="bi bi-calendar3"></i> @item.CreatedDate.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-newspaper text-muted" style="font-size: 3rem;"></i>
                <p class="text-muted fs-5 mt-2">Hệ thống chưa có bản tin nào.</p>
            </div>
        }
    </div>
</div>

<style>
    .post-card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .post-card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }
</style>