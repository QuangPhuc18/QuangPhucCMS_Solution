@model IEnumerable<CMS_DATA.Entities.Post>

@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2">
        <h2 class="text-danger fw-bold text-uppercase mb-0 border-start border-danger border-4 ps-2">
            Tin Tức Mới Nhất
        </h2>
        <a asp-controller="Posts" asp-action="Index" class="text-decoration-none text-muted">Xem tất cả &rarr;</a>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm h-100 border-0">

                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/400x250?text=News" : item.ImageUrl)"
                             class="card-img-top"
                             alt="@item.Title"
                             style="height: 200px; object-fit: cover;">

                        <div class="card-body d-flex flex-column">
                            <div class="mb-2">
                                <span class="badge bg-primary">
                                    @(item.Category != null ? item.Category.Name : "Chưa phân loại")
                                </span>
                            </div>

                            <h5 class="card-title fw-bold">@item.Title</h5>

                            <p class="card-text text-muted" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.Content
                            </p>

                            <div class="mt-auto pt-3">
                                <a asp-controller="Posts" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm w-100">
                                    Đọc tiếp
                                </a>
                            </div>
                        </div>

                        <div class="card-footer bg-white text-muted small border-top-0">
                            <i class="bi bi-calendar3"></i> @item.CreatedDate.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted fs-5">Hệ thống chưa có bản tin nào.</p>
            </div>
        }
    </div>
</div>