@model IEnumerable<CMS_DATA.Entities.Order>

@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold text-uppercase border-start border-4 border-primary ps-2">
            <i class="bi bi-cart-check-fill"></i> Quản Lý Đơn Hàng
        </h2>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center">Mã ĐH</th>
                            <th>Khách Hàng</th>
                            <th>Ngày Đặt</th>
                            <th class="text-center">Trạng Thái</th>
                            <th class="text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold text-secondary">#@item.Id</td>
                                    <td class="fw-bold">@(item.Customer != null ? item.Customer.FullName : "Khách vãng lai")</td>
                                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center">
                                        @if (item.Status == 0)
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2">Chờ duyệt</span>
                                        }
                                        else if (item.Status == 1)
                                        {
                                            <span class="badge bg-info text-dark px-3 py-2">Đang giao</span>
                                        }
                                        else if (item.Status == 2)
                                        {
                                            <span class="badge bg-success px-3 py-2">Đã xong</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Xem hóa đơn">
                                            Chi tiết
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Cập nhật trạng thái">
                                            Cập nhật
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">Chưa có đơn hàng nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>