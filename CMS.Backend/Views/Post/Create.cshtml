@model CMS_DATA.Entities.Post

@{
    ViewData["Title"] = "Viết Bài Mới";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0 text-uppercase fw-bold"><i class="bi bi-file-earmark-plus"></i> Viết Bài Mới</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-8">
                                <div class="mb-4">
                                    <label asp-for="Title" class="form-label fw-bold">Tiêu đề bài viết <span class="text-danger">*</span></label>
                                    <input asp-for="Title" class="form-control form-control-lg" placeholder="Nhập tiêu đề thật hấp dẫn..." autofocus />
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="Content" class="form-label fw-bold">Nội dung bài viết</label>
                                    <textarea asp-for="Content" class="form-control" rows="12" placeholder="Nội dung chi tiết..."></textarea>
                                    <span asp-validation-for="Content" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="card border mb-4">
                                    <div class="card-header bg-light fw-bold">Phân Loại</div>
                                    <div class="card-body">
                                        <label asp-for="CategoryId" class="form-label">Chọn chuyên mục <span class="text-danger">*</span></label>
                                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                            <option value="">-- Chọn danh mục --</option>
                                        </select>
                                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="card border mb-4">
                                    <div class="card-header bg-light fw-bold">Ảnh Đại Diện</div>
                                    <div class="card-body">
                                        <label asp-for="ImageUrl" class="form-label">Link ảnh (URL)</label>
                                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                                        <div class="form-text">Dán đường dẫn hình ảnh vào đây.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted" />

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <a asp-action="Index" class="btn btn-light border px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-success px-5 fw-bold">XUẤT BẢN BÀI VIẾT</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}