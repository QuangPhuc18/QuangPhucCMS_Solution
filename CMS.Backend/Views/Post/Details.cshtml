@model CMS_DATA.Entities.Post

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Danh sách bài viết</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết bài viết</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-10">

            <div class="mb-3">
                <span class="badge bg-primary fs-6 px-3 py-2 shadow-sm">
                    📁 Chuyên mục: @(Model.Category != null ? Model.Category.Name : "Chưa phân loại")
                </span>
            </div>

            <h1 class="display-4 fw-bold text-primary mb-3">@Model.Title</h1>
            <p class="text-muted mb-4">
                <i class="bi bi-clock"></i> Đăng ngày: @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
            </p>

            <hr class="mb-4" />

            @if (!string.IsNullOrEmpty(Model.ImageUrl)) 
            {
                <div class="text-center mb-5">
                    <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Title" style="width: 100%; max-height: 500px; object-fit: cover;">
                </div>
            }

            <div class="post-content fs-5 leading-lg" style="line-height: 1.8; text-align: justify;">
                @Model.Content
            </div>

            <div class="mt-5 border-top pt-4 mb-5">
                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
            </div>

        </div>
    </div>
</div>