@model CMS_DATA.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="container mt-4 mb-5">
    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-uppercase fw-bold"><i class="bi bi-file-earmark-text"></i> Chi Tiết Bài Viết #@Model.Id</h5>
            <span class="badge bg-info text-dark fw-bold fs-6">
                <i class="bi bi-folder"></i> @(Model.Category != null ? Model.Category.Name : "Chưa phân loại")
            </span>
        </div>

        <div class="card-body p-4">
            <h1 class="text-primary fw-bold mb-3">@Model.Title</h1>

            <p class="text-muted small border-bottom pb-2">
                <i class="bi bi-calendar3"></i> Ngày đăng: @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
            </p>

            <div class="row mt-4">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="col-md-10 text-center mb-4">
                        <img src="@Model.ImageUrl" alt="Thumbnail" class="img-fluid rounded shadow-sm" style="max-height: 400px; width: 100%; object-fit: cover;" />
                    </div>
                }

                <div class="col-12 fs-5 text-dark lh-base post-content mt-2">
                    @Html.Raw(Model.Content)
                </div>
            </div>

            <hr class="text-muted mt-5" />

            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-secondary px-4 fw-bold">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 fw-bold text-dark">
                    <i class="bi bi-pencil-square"></i> Sửa bài viết
                </a>
            </div>
        </div>
    </div>
</div>