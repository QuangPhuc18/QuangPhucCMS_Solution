@model CMS_DATA.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-4 mb-5">
    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-warning text-dark py-3">
            <h5 class="mb-0 text-uppercase fw-bold"><i class="bi bi-pencil-square"></i> CẬP NHẬT BÀI VIẾT #@Model.Id</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedDate" />

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề bài viết:</label>
                            <input asp-for="Title" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nội dung chi tiết:</label>
                            <textarea asp-for="Content" id="Content" class="form-control" rows="10"></textarea>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chuyên mục:</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Đổi ảnh đại diện (Choose File):</label>
                            <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                            <small class="text-muted d-block mt-1">Để trống nếu không muốn đổi ảnh.</small>

                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="mt-3 text-center p-2 border rounded bg-light">
                                    <p class="mb-2 fw-bold text-secondary" style="font-size: 0.85rem;">ẢNH HIỆN TẠI</p>
                                    <img src="@Model.ImageUrl?v=@DateTime.Now.Ticks" class="img-fluid rounded shadow-sm" style="max-height: 150px; object-fit: cover;" />
                                </div>
                            }
                        </div>

                        <hr />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold text-dark">
                                <i class="bi bi-save"></i> LƯU THAY ĐỔI
                            </button>
                            <a asp-action="Index" class="btn btn-secondary fw-bold">
                                <i class="bi bi-arrow-left"></i> QUAY LẠI
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#Content'))
            .catch(error => { console.error(error); });
    </script>
}