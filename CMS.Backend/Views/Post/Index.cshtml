@model IEnumerable<CMS_DATA.Entities.Post>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh Sách Bài Viết";
}
@{
    ViewData["Title"] = "Danh sách bài viết";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger mb-0">DANH SÁCH BÀI VIẾT MỚI NHẤT</h2>
        <a asp-action="Create" class="btn btn-success"> + Viết bài mới</a>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100">
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300x200?text=No+Image" : item.ImageUrl)"
                             class="card-img-top"
                             style="height: 200px; object-fit: cover;"
                             alt="@item.Title">

                        <div class="card-body d-flex flex-column">
                            <div class="mb-2">
                                <span class="badge bg-info text-dark">
                                    @(item.Category != null ? item.Category.Name : "Chưa phân loại")
                                </span>
                            </div>

                            <h5 class="card-title text-primary">@item.Title</h5>
                            <p class="card-text text-truncate">@item.Content</p>
                            <p class="text-muted small mb-3">Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</p>

                            <div class="mt-auto">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">Sửa</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center mt-5">
                <p class="text-muted">Không tìm thấy bài viết nào phù hợp.</p>
                <a asp-action="Index" class="btn btn-outline-secondary mt-2">Quay lại tất cả bài viết</a>
            </div>
        }
    </div>
</div>