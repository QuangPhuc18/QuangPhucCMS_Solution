@model CMS_DATA.Entities.Product

@{
    ViewData["Title"] = "Cập Nhật Sản Phẩm";
    Layout = "_LayoutAdmin";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0 text-uppercase fw-bold"><i class="bi bi-pencil-square"></i> Cập Nhật Sản Phẩm #@Model.Id</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="row">
                            <div class="col-md-7">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                                    <input asp-for="Name" class="form-control" />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Price" class="form-label fw-bold">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                                        <input asp-for="Price" type="number" min="0" onkeypress="return event.charCode >= 48 && event.charCode <= 57" class="form-control" />
                                        <span asp-validation-for="Price" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="StockQuantity" class="form-label fw-bold">Tồn kho <span class="text-danger">*</span></label>
                                        <input asp-for="StockQuantity" type="number" min="0" onkeypress="return event.charCode >= 48 && event.charCode <= 57" class="form-control" />
                                        <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                                </div>
                            </div>

                            <div class="col-md-5">
                                <div class="card border mb-4 shadow-sm">
                                    <div class="card-header bg-light fw-bold">Phân Loại Danh Mục</div>
                                    <div class="card-body">
                                        <label asp-for="CategoryProductId" class="form-label">Đổi danh mục</label>
                                        <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryList">
                                            <option value="">-- Chọn danh mục --</option>
                                        </select>
                                        <span asp-validation-for="CategoryProductId" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="card border shadow-sm">
                                    <div class="card-header bg-light fw-bold">Hình Ảnh Hiện Tại</div>
                                    <div class="card-body">
                                        <label class="form-label">Tải ảnh mới (Nếu muốn đổi)</label>
                                        <input type="file" name="uploadImage" class="form-control mb-3" accept="image/*" />

                                        @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                                        {
                                            <div class="text-center mt-2">
                                                <p class="small text-muted mb-1">Ảnh đang dùng:</p>
                                                <img src="@Model.ImageUrl" alt="Thumbnail" class="img-thumbnail shadow-sm" style="max-height: 150px; object-fit: cover;" />
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted mt-4" />

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light border px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-warning px-5 fw-bold text-dark">LƯU THAY ĐỔI</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}