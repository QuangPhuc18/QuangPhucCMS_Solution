<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMS Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                display: block;
                padding: 12px 20px;
                transition: 0.3s;
            }

                .sidebar a:hover, .sidebar .active {
                    background-color: #0d6efd;
                    color: white;
                    border-radius: 5px;
                    margin: 0 10px;
                }

        main {
            background-color: #f8f9fa;
            min-height: 100vh;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 sidebar p-0 shadow">
                <div class="p-3 text-center border-bottom border-secondary mb-3">
                    <h4 class="text-white fw-bold"><i class="bi bi-shield-lock"></i> ADMIN PANEL</h4>
                </div>
                <div>
                    <a asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i> Bảng điều khiển</a>
                    <a asp-controller="Category" asp-action="Index"><i class="bi bi-tags me-2"></i> Danh mục </a>
                    <a asp-controller="Post" asp-action="Index"><i class="bi bi-file-earmark-text me-2"></i> Bài viết (Tin tức)</a>
                    <a asp-controller="Product" asp-action="Index"><i class="bi bi-box-seam me-2"></i> Quản lý Sản phẩm</a>
                    <a asp-controller="Customer" asp-action="Index"><i class="bi bi-person-vcard me-2"></i> Khách hàng</a>
                    <a asp-controller="Order" asp-action="Index"><i class="bi bi-cart-check me-2"></i> Đơn hàng</a>
                    <a asp-controller="User" asp-action="Index"><i class="bi bi-people me-2"></i> Thành viên (Admin)</a>
                </div>
            </nav>

            <main class="col-md-9 col-lg-10 ms-sm-auto p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>